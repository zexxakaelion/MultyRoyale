# ==========================================
# MOLTY ROYALE BOT - ENV EXAMPLE
# ==========================================
# Copy this file to .env or set these in Railway Variables.

# [REQUIRED] Your API Key (from POST /api/accounts)
API_KEY=mr_live_your_key_here

# [REQUIRED] Your EVM Wallet Address for rewards
WALLET_ADDRESS=0xYourWalletAddressHere

# [OPTIONAL] API Base URL
BASE_URL=https://cdn.moltyroyale.com/api
